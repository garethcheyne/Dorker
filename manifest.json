{
  "manifest_version": 3,
  "name": "Dorker - Google Dork Assistant",
  "version": "2026.04.14",
  "description": "Autocomplete and assistant for Google dorking operators in the search box",
  "permissions": ["sidePanel", "activeTab", "storage", "alarms", "tabs"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Dork Help"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/*",
        "*://www.google.co.uk/*",
        "*://www.google.co.za/*",
        "*://www.google.co.nz/*",
        "*://www.google.co.in/*",
        "*://www.google.co.jp/*",
        "*://www.google.co.kr/*",
        "*://www.google.co.id/*",
        "*://www.google.co.th/*",
        "*://www.google.com.au/*",
        "*://www.google.com.br/*",
        "*://www.google.com.mx/*",
        "*://www.google.com.ar/*",
        "*://www.google.com.sg/*",
        "*://www.google.com.hk/*",
        "*://www.google.com.tw/*",
        "*://www.google.com.tr/*",
        "*://www.google.com.ua/*",
        "*://www.google.ca/*",
        "*://www.google.de/*",
        "*://www.google.fr/*",
        "*://www.google.es/*",
        "*://www.google.it/*",
        "*://www.google.nl/*",
        "*://www.google.pl/*",
        "*://www.google.ru/*",
        "*://www.google.se/*",
        "*://www.google.ch/*",
        "*://www.google.at/*",
        "*://www.google.be/*",
        "*://www.google.pt/*",
        "*://www.google.ie/*",
        "*://www.google.dk/*",
        "*://www.google.fi/*",
        "*://www.google.no/*",
        "*://www.google.cz/*",
        "*://www.google.ro/*",
        "*://www.google.hu/*",
        "*://www.google.cl/*",
        "*://www.google.ae/*"
      ],
      "js": ["src/content/index.ts"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
