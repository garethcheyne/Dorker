{
  "manifest_version": 3,
  "name": "Dorker - Google Dork Assistant",
  "version": "1.0.0",
  "description": "Autocomplete and assistant for Google dorking operators in the search box",
  "permissions": [
    "sidePanel",
    "activeTab"
  ],
  "action": {
    "default_icon": "dork.png",
    "default_title": "Dork Help"
  },
  "icons": {
    "128": "dork.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-MjsC9UQA.js"
      ],
      "matches": [
        "*://www.google.com/*",
        "*://www.google.co.uk/*",
        "*://www.google.co.za/*",
        "*://www.google.co.nz/*",
        "*://www.google.co.in/*",
        "*://www.google.co.jp/*",
        "*://www.google.co.kr/*",
        "*://www.google.co.id/*",
        "*://www.google.co.th/*",
        "*://www.google.com.au/*",
        "*://www.google.com.br/*",
        "*://www.google.com.mx/*",
        "*://www.google.com.ar/*",
        "*://www.google.com.sg/*",
        "*://www.google.com.hk/*",
        "*://www.google.com.tw/*",
        "*://www.google.com.tr/*",
        "*://www.google.com.ua/*",
        "*://www.google.ca/*",
        "*://www.google.de/*",
        "*://www.google.fr/*",
        "*://www.google.es/*",
        "*://www.google.it/*",
        "*://www.google.nl/*",
        "*://www.google.pl/*",
        "*://www.google.ru/*",
        "*://www.google.se/*",
        "*://www.google.ch/*",
        "*://www.google.at/*",
        "*://www.google.be/*",
        "*://www.google.pt/*",
        "*://www.google.ie/*",
        "*://www.google.dk/*",
        "*://www.google.fi/*",
        "*://www.google.no/*",
        "*://www.google.cz/*",
        "*://www.google.ro/*",
        "*://www.google.hu/*",
        "*://www.google.cl/*",
        "*://www.google.ae/*"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://www.google.ae/*",
        "*://www.google.at/*",
        "*://www.google.be/*",
