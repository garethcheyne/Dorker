        "*://www.google.ch/*",
        "*://www.google.cl/*",
        "*://www.google.co.id/*",
        "*://www.google.co.in/*",
        "*://www.google.co.jp/*",
        "*://www.google.co.kr/*",
        "*://www.google.co.nz/*",
        "*://www.google.co.th/*",
        "*://www.google.co.uk/*",
        "*://www.google.co.za/*",
        "*://www.google.com.ar/*",
        "*://www.google.com.au/*",
        "*://www.google.com.br/*",
        "*://www.google.com.hk/*",
        "*://www.google.com.mx/*",
        "*://www.google.com.sg/*",
        "*://www.google.com.tr/*",
        "*://www.google.com.tw/*",
        "*://www.google.com.ua/*",
        "*://www.google.com/*",
        "*://www.google.cz/*",
