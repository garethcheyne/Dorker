        "*://www.google.ru/*",
        "*://www.google.se/*"
      ],
      "resources": [
        "assets/dork-CYarL3Sn.png",
        "assets/chunk-CZOpNEXY.js",
        "assets/dork-BpKlhgqE.js",
        "assets/index.ts-Co24jCtG.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
